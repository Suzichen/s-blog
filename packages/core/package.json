{
  "name": "@s-blog/core",
  "version": "0.5.4",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/index.css"
  },
  "files": [
    "dist/",
    "schemas/"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "build:shell": "vite build --config vite.shell.config.ts",
    "build:all": "bun run build && bun run build:shell",
    "prepublishOnly": "bun run build:all",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@types/github-slugger": "^1.3.0",
    "date-fns": "^4.1.0",
    "exifr": "^7.1.3",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "heic-decode": "^2.1.0",
    "i18next": "^25.7.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "prismjs": "^1.30.0",
    "react-i18next": "^16.5.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.10.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "wasm-vips": "^0.0.17"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.23",
    "fast-check": "^4.8.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.7"
  },
  "keywords": [
    "blog",
    "react",
    "vite",
    "s-blog"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Suzichen/s-blog.git"
  },
  "bugs": {
    "url": "https://github.com/Suzichen/s-blog/issues"
  },
  "homepage": "https://s-blog.me"
}
