{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://unpkg.com/@s-page/core/schemas/album.config.schema.json",
  "title": "spage Album Configuration",
  "description": "Configuration schema for spage album/photo gallery settings",
  "type": "object",
  "required": ["enabled", "albums"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference URL for editor intellisense"
    },
    "enabled": {
      "type": "boolean",
      "description": "Enable or disable the album module"
    },
    "albums": {
      "type": "array",
      "description": "List of album configurations",
      "items": {
        "type": "object",
        "required": ["dir"],
        "properties": {
          "dir": {
            "type": "string",
            "description": "Directory name relative to albums/"
          },
          "name": {
            "type": "string",
            "description": "Display name for the album (optional, defaults to dir)"
          },
          "cover": {
            "type": "string",
            "description": "Cover image filename (optional, auto-selected if not set)"
          }
        },
        "additionalProperties": false
      }
    },
    "provider": {
      "type": "object",
      "description": "S3-compatible storage provider for external media hosting",
      "required": ["type", "endpoint", "region", "bucket", "publicUrl"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["s3"],
          "description": "Provider type (currently only 's3' is supported)"
        },
        "endpoint": {
          "type": "string",
          "description": "S3 endpoint URL (e.g. https://<account_id>.r2.cloudflarestorage.com)"
        },
        "region": {
          "type": "string",
          "description": "S3 region (e.g. 'auto' for R2, 'ap-northeast-1' for AWS)"
        },
        "bucket": {
          "type": "string",
          "description": "S3 bucket name"
        },
        "publicUrl": {
          "type": "string",
          "description": "Public CDN URL for serving original images"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
