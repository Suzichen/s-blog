{
  "name": "new-blog",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "workspaces": ["packages/*", "crates/*"],
  "scripts": {
    "dev": "bun crates/spage-engine-napi/bin/spage.cjs serve",
    "build:core": "bun run --filter @s-page/core build:all",
    "build": "bun run build:core && bun crates/spage-engine-napi/bin/spage.cjs build",
    "test": "vitest run --config vitest.config.ts",
    "test:golden": "bun tests/generate-golden.ts"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "vitest": "^4.1.9",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "gray-matter": "^4.0.3",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "vite": "^8.1.2"
  },
  "dependencies": {
    "@s-page/core": "workspace:*",
    "@s-page/engine": "0.6.3",
    "@types/github-slugger": "^1.3.0",
    "date-fns": "^4.4.0",
    "exifr": "^7.1.3",
    "github-slugger": "^2.0.0",
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "prismjs": "^1.30.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^16.6.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "heic-decode": "^2.1.0",
    "wasm-vips": "^0.0.17"
  }
}
