{
  "name": "new-blog",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "node crates/s-blog-engine-napi/bin/s-blog.cjs serve",
    "dev:vite": "vite",
    "build:core": "npm run build:all -w packages/core",
    "build": "npm run build:core && node crates/s-blog-engine-napi/bin/s-blog.cjs build",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "test:golden": "npx tsx tests/generate-golden.ts"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "vitest": "^3.2.4",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "gray-matter": "^4.0.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4"
  },
  "dependencies": {
    "@s-blog/core": "workspace:*",
    "@s-blog/engine": "0.3.11",
    "@types/github-slugger": "^1.3.0",
    "date-fns": "^4.1.0",
    "exifr": "^7.1.3",
    "github-slugger": "^2.0.0",
    "i18next": "^25.7.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "prismjs": "^1.30.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-i18next": "^16.5.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.10.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "heic-decode": "^2.1.0",
    "wasm-vips": "^0.0.17"
  }
}
