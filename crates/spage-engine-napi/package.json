{
  "name": "@s-page/engine",
  "version": "0.6.0",
  "description": "Rust-powered data engine for spage — Markdown parsing, image processing, SEO/feed generation",
  "license": "MIT",
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "spage": "./bin/spage.cjs",
    "s-blog": "./bin/spage.cjs"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "bin/spage.cjs",
    "README.md"
  ],
  "napi": {
    "binaryName": "spage-engine-napi",
    "targets": [
      "x86_64-pc-windows-msvc",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform"
  },
  "optionalDependencies": {
    "@s-page/engine-win32-x64-msvc": "0.6.0",
    "@s-page/engine-darwin-arm64": "0.6.0",
    "@s-page/engine-linux-x64-gnu": "0.6.0"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Suzichen/spage.git"
  },
  "engines": {
    "node": ">= 16"
  },
  "bugs": {
    "url": "https://github.com/Suzichen/spage/issues"
  },
  "homepage": "https://spage.me"
}